{
  "version": 2,
  "name": "marsha-jkt48-bot",
  "functions": {
    "api/cron.js": {
      "maxDuration": 60
    },
    "api/status.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
